---
type PricingTier = {
	name: string;
	price: string;
	description: string;
	idealFor: string;
	turnaround: string;
	featured?: boolean;
	items: string[];
};

const pricingTiers: PricingTier[] = [
	{
		name: 'Start web',
		price: 'do 8 000 Kč',
		description: 'Jednoduchý prezentační web nebo landing page pro živnostníky a malé služby.',
		idealFor: 'Ideální pro: řemeslníky, konzultanty, menší lokální podnikání',
		turnaround: 'Dodání obvykle za 1 až 2 týdny',
		items: [
			'1 až 3 podstránky nebo one-page řešení',
			'Responzivní zobrazení pro mobil i desktop',
			'Kontaktní formulář a základní SEO nastavení',
			'Nasazení na hosting a předání hotového webu'
		]
	},
    {
        name: 'Standardní web',
        price: 'od 8 000 Kč',
        description: 'Web na míru s rozšířenými funkcemi a designem.',
        idealFor: 'Ideální pro: malé a střední podniky, restaurace, blogy',
        turnaround: 'Dodání obvykle za 2 až 3 týdny',
		featured: true,
        items: [
            '3 až 5 podstránek s vlastním rozložením',
            'Responzivní zobrazení pro mobil i desktop',
            'Kontaktní formulář, základní SEO a analytika',
            'Nasazení na hosting a předání hotového webu'
        ]
    },
	{
		name: 'Firemní web',
		price: 'od 28 000 Kč',
		description: 'Kompletní firemní prezentace na míru s důrazem na důvěryhodnost a rychlost.',
		idealFor: 'Ideální pro: firmy, studia, ordinace, e-shopy',
		turnaround: 'Dodání obvykle za 3 a více týdnů',
		items: [
			'4 až 8 podstránek s vlastním rozložením',
			'Návrh struktury obsahu a doporučení k textům',
			'Formuláře, reference, ceník, blog nebo FAQ sekce',
			'Technické SEO, analytika a napojení základních nástrojů'
		]
	}
];


---

<div class="container mx-auto px-4 text-center">
    <h1 class="text-4xl md:text-6xl mb-16">
        Ceník tvorby webů
    </h1>

	<div class="grid gap-8 lg:grid-cols-3">
		{pricingTiers.map((tier) => (
			<article class={`flex h-full flex-col rounded-3xl border p-8 text-left shadow-xl/20 transition-transform duration-300 hover:-translate-y-1 ${tier.featured ? 'border-[#BCD8C1] bg-linear-to-b from-[#BCD4A0]/90 to-[#439A86]/95 text-slate-900' : 'border-slate-500 bg-[#439A86]/90 text-white'}`}>
				<div class="mb-6 flex items-start justify-between gap-4">
					<div>
						<p class={`mb-2 text-sm font-bold uppercase tracking-[0.25em] ${tier.featured ? 'text-slate-800/80' : 'text-[#BCD8C1]'}`}>
							{tier.name}
						</p>
						<h3 class="text-3xl font-extrabold">{tier.price}</h3>
					</div>
                    {tier.featured && (
						<span class="rounded-full border border-slate-700/20 bg-white/50 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-slate-900">
							Nejčastější volba
						</span>
					)}
				</div>

				<p class={`mb-5 text-base leading-7 ${tier.featured ? 'text-slate-800' : 'text-white'}`}>
					{tier.description}
				</p>

				<div class={`mb-6 space-y-3 rounded-2xl border p-4 ${tier.featured ? 'border-slate-700/15 bg-white/35' : 'border-white/10 bg-[#222E50]/25'}`}>
					<p class={`text-sm font-semibold ${tier.featured ? 'text-slate-900' : 'text-[#d4e6d8]'}`}>
						{tier.idealFor}
					</p>
					<p class={`text-sm ${tier.featured ? 'text-slate-800' : 'text-white'}`}>
						{tier.turnaround}
					</p>
				</div>

				<ul class="mb-8 space-y-3">
					{tier.items.map((item) => (
						<li class="flex items-start gap-3">
							<span class={`mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full text-sm font-bold ${tier.featured ? 'bg-slate-900 text-white' : 'bg-[#BCD8C1] text-slate-900'}`}>
								✓
							</span>
							<span class={`leading-7 ${tier.featured ? 'text-slate-900' : 'text-white'}`}>{item}</span>
						</li>
					))}
				</ul>

				<a
					href="#kontakt"
					class={`mt-auto inline-flex items-center justify-center rounded-xl border px-5 py-3 text-center font-bold transition ${tier.featured ? 'border-slate-900 bg-slate-900 text-white hover:bg-slate-800' : 'border-slate-400 bg-[#BCD8C1]/90 text-slate-900 hover:bg-[#BCD8C1]'}`}
				>
					Nezávazně poptat
				</a>
			</article>
		))}
	</div>

	<div class="mt-10 rounded-3xl border border-slate-500 bg-[#222E50]/60 p-6 text-left text-white shadow-xl/10">
		<p class="text-base leading-7 md:text-lg">
			Uvedené ceny jsou orientační. Finální nabídku připravuji podle konkrétního zadání, počtu podstránek,
			náročnosti funkcí a toho, jestli dodáváte vlastní texty, grafiku a podklady. Doména, hosting, placené licence
			a copywriting třetích stran se obvykle řeší samostatně.
		</p>
	</div>
</div>
