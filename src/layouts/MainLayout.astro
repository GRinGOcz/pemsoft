---
const { title = "Programátor webů" } = Astro.props;
import "../styles/global.css";

const navLinks = [
  { href: "#o-mne", label: "O mně" },
  //{ href: "#reference", label: "Reference" },
  { href: "#kontakt", label: "Kontakt" }
];
---

<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  
  <body class="bg-[#222E50] text-white font-sans">
    
    <nav class="p-6 border-b border-[#404551] sticky top-0 bg-[#222E50]/80 backdrop-blur-md z-50">
      <div class="max-w-6xl mx-auto flex justify-end items-center relative min-h-8">
        
        <a href="#hero" id="main-logo" class="text-xl font-bold z-20 absolute transition-all duration-700 ease-in-out no-transition" style="left: 50%; transform: translateX(-50%) scale(1.5);">
      PeMSoft
    </a>

        <div id="active-section-display" class="text-white font-medium absolute left-1/2 -translate-x-1/2 pointer-events-none z-10 transition-all duration-300 opacity-0 translate-y-2">
    </div>
        
        <div id="toggle-menu" class="md:hidden cursor-pointer z-50 w-10 h-10 flex items-center justify-center relative">
      <div class="hamburger-line"></div>
    </div>

        <div class="space-x-6 hidden md:flex">
          {navLinks.map(link => (
            <a href={link.href} class="nav-link hover:text-[#007991] transition-colors">{link.label}</a>
          ))}
        </div>
      </div>
    </nav>

    <div id="mobile-menu" class="fixed inset-0 bg-[#222E50] z-40 invisible opacity-0 transition-all duration-500 ease-in-out md:hidden flex flex-col items-center justify-center space-y-8 text-2xl font-bold">
      <a href="#hero" class="mobile-nav-link hover:text-[#007991] transition-all duration-500 opacity-0 translate-y-8">Domů</a>
      {navLinks.map((link, index) => (
        <a href={link.href} class="mobile-nav-link hover:text-[#007991] transition-all duration-500 opacity-0 translate-y-8"
        style={`transition-delay: ${index * 100 + 150}ms`}
        >
          {link.label}
        </a>
      ))}
    </div>

    <main>
      <slot />
    </main>

    <footer class="p-10 border-t border-[#404551] text-center text-slate-500">
      <p>&copy; {new Date().getFullYear()} - Petr Meca</p>
    </footer>

    <style>
      #main-logo.no-transition {
        transition: none !important;
      }

      .hamburger-line {
        width: 32px;
        height: 3px;
        background-color: white;
        border-radius: 99px;
        transition: all 0.3s ease-in-out;
        position: relative;
      }

      .hamburger-line::before,
      .hamburger-line::after {
        content: "";
        position: absolute;
        width: 32px;
        height: 3px;
        background-color: white;
        border-radius: 99px;
        transition: all 0.3s ease-in-out;
        left: 0;
      }

      .hamburger-line::before { transform: translateY(-10px); }
      .hamburger-line::after { transform: translateY(10px); }

      .is-active .hamburger-line {
        background-color: transparent;
      }

      .is-active .hamburger-line::before {
        transform: translateY(0) rotate(45deg);
      }

      .is-active .hamburger-line::after {
        transform: translateY(0) rotate(-45deg);
      }

      main {
        position: relative;
        overflow: hidden;
      }

      main::before {
        content: "";
        position: fixed; /* Nahrazuje bg-fixed */
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('../assets/bg.png');
        background-size: cover;
        background-position: center;
        z-index: -1; 
        opacity: 0.3;
        filter: blur(8px);
      }
    </style>
    <script>
      function getRequiredElement<T extends Element>(selector: string): T {
        const element = document.querySelector<T>(selector);

        if (!element) {
          throw new Error(`Missing required element: ${selector}`);
        }

        return element;
      }

      let isScrollingManual = false;
      let currentActiveSectionId: string | null = null;
      const mainLogo = getRequiredElement<HTMLAnchorElement>('#main-logo');
      const toggleMenu = getRequiredElement<HTMLDivElement>('#toggle-menu');
      const mobileMenu = getRequiredElement<HTMLDivElement>('#mobile-menu');
      const mobileLinks = document.querySelectorAll<HTMLAnchorElement>('.mobile-nav-link');
      const sectionDisplay = getRequiredElement<HTMLDivElement>('#active-section-display');

      function updateLogoPosition(isHero: boolean): void {
        if (isHero) {
          mainLogo.style.left = '50%';
          mainLogo.style.transform = 'translateX(-50%) scale(1.5)';
          return;
        }

        mainLogo.style.left = '0%';
        mainLogo.style.transform = 'translateX(0%) scale(1)';
      }

      function sectionDisplayText(sectionName: string): void {
        if (sectionDisplay.innerText === sectionName) {
          return;
        }

        sectionDisplay.style.transition = 'opacity 0.2s ease-in-out, transform 0.2s ease-out';
        sectionDisplay.style.opacity = '0';
        sectionDisplay.style.transform = 'translateY(5px)';

        setTimeout(() => {
          sectionDisplay.innerText = sectionName;

          if (sectionName !== '') {
            sectionDisplay.style.opacity = '1';
            sectionDisplay.style.transform = 'translateY(0)';
          }
        }, 200);
      }

      function getActiveLink(id: string): HTMLAnchorElement | null {
        return document.querySelector<HTMLAnchorElement>(`.nav-link[href="#${id}"]`) ??
          document.querySelector<HTMLAnchorElement>(`.mobile-nav-link[href="#${id}"]`);
      }

      function applyActiveSection(id: string): void {
        if (!id || id === currentActiveSectionId) {
          return;
        }

        currentActiveSectionId = id;
        updateLogoPosition(id === 'hero');

        document.querySelectorAll<HTMLElement>('.nav-link').forEach((link) => {
          link.classList.remove('text-[#007991]', 'font-bold');
        });

        const desktopLink = document.querySelector<HTMLElement>(`.nav-link[href="#${id}"]`);
        desktopLink?.classList.add('text-[#007991]', 'font-bold');

        if (id === 'hero') {
          sectionDisplayText('');
          return;
        }

        sectionDisplayText(getActiveLink(id)?.innerText ?? '');
      }

      function toggleAll(): void {
        const isOpening = mobileMenu.classList.contains('opacity-0');

        toggleMenu.classList.toggle('is-active');
        mobileMenu.classList.toggle('invisible');
        mobileMenu.classList.toggle('opacity-0');
        mobileMenu.classList.toggle('opacity-100');

        mobileLinks.forEach((link) => {
          link.style.transitionDelay = isOpening ? '' : '0ms';
          link.classList.toggle('opacity-0');
          link.classList.toggle('opacity-100');
          link.classList.toggle('translate-y-8');
          link.classList.toggle('translate-y-0');
        });

        document.body.classList.toggle('overflow-hidden');
      }

      toggleMenu.onclick = toggleAll;

      mobileLinks.forEach((link) => {
        link.onclick = () => {
          if (mobileMenu.classList.contains('opacity-100')) {
            toggleAll();
          }
        };
      });

      mainLogo.onclick = () => {
        if (mobileMenu.classList.contains('opacity-100')) {
          toggleAll();
        }
      };

      const observerOptions: IntersectionObserverInit = {
        root: null,
        rootMargin: '-40% 0px -40% 0px',
        threshold: 0
      };

      const observer = new IntersectionObserver((entries) => {
        const intersectingEntries = entries.filter((entry) => entry.isIntersecting);

        if (!intersectingEntries.length) {
          return;
        }

        const viewportCenter = window.innerHeight / 2;
        let bestEntry: IntersectionObserverEntry | null = null;
        let bestDistance = Number.POSITIVE_INFINITY;

        for (const entry of intersectingEntries) {
          const rect = entry.target.getBoundingClientRect();
          const sectionCenter = rect.top + rect.height / 2;
          const distance = Math.abs(sectionCenter - viewportCenter);

          if (distance < bestDistance) {
            bestEntry = entry;
            bestDistance = distance;
          }
        }

        if (!bestEntry) {
          return;
        }

        const id = bestEntry.target.id;

        if (isScrollingManual) {
          if (id === 'hero') {
            sectionDisplayText('');
          } else {
            sectionDisplayText(getActiveLink(id)?.innerText ?? '');
          }
          return;
        }

        applyActiveSection(id);
      }, observerOptions);

      document.querySelectorAll('section[id]').forEach((section) => {
        observer.observe(section);
      });

      document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', (event) => {
          event.preventDefault();

          const targetId = anchor.getAttribute('href');
          if (!targetId) {
            return;
          }

          const targetElement = document.querySelector<HTMLElement>(targetId);
          if (!targetElement) {
            return;
          }

          isScrollingManual = true;
          applyActiveSection(targetId.replace('#', ''));
          updateLogoPosition(targetId === '#hero');
          targetElement.scrollIntoView({ behavior: 'smooth' });

          setTimeout(() => {
            isScrollingManual = false;
          }, 800);
        });
      });

      function initializeSectionState(): void {
        const sections = document.querySelectorAll<HTMLElement>('section[id]');
        let currentSectionId = 'hero';

        const hashId = window.location.hash.replace('#', '');
        if (hashId && document.getElementById(hashId)?.matches('section[id]')) {
          currentSectionId = hashId;
        } else {
          const midViewport = window.innerHeight / 2;

          sections.forEach((section) => {
            const rect = section.getBoundingClientRect();

            if (rect.top <= midViewport && rect.bottom >= midViewport) {
              currentSectionId = section.id;
            }
          });
        }

        applyActiveSection(currentSectionId);

        requestAnimationFrame(() => {
          mainLogo.classList.remove('no-transition');
        });

        setTimeout(() => {
          mainLogo.classList.remove('no-transition');
        }, 50);
      }

      if (document.readyState === 'loading') {
        window.addEventListener('DOMContentLoaded', initializeSectionState);
      } else {
        initializeSectionState();
      }

      window.addEventListener('hashchange', () => {
        const hashId = window.location.hash.replace('#', '');

        if (hashId && document.getElementById(hashId)?.matches('section[id]')) {
          applyActiveSection(hashId);
        }
      });
    </script>
  </body>
</html> 